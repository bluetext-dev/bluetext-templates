#!/bin/sh
set -e

BACKEND_NAMESPACE="${BACKEND_NAMESPACE:-${BLUETEXT_NAMESPACE:-dev}}"

# Wait for emulator to be reachable via ADB
echo "Waiting for Android emulator..."
while ! adb devices 2>/dev/null | grep -q "emulator"; do
  sleep 2
done
DEVICE=$(adb devices | grep "emulator" | head -1 | awk '{print $1}')
echo "Connected to $DEVICE"

# Package name derived from applicationId in build.gradle
PKG="com.example.workspace"

build_and_install() {
  echo "Building APK..."
  flutter build apk --debug \
    --dart-define=BACKEND_NAMESPACE="$BACKEND_NAMESPACE" \
    --android-skip-build-dependency-validation 2>&1
  APK="build/app/outputs/flutter-apk/app-debug.apk"
  echo "Installing on $DEVICE..."
  # Try install; if signature mismatch, uninstall first and retry
  if ! adb -s "$DEVICE" install -r "$APK" 2>&1; then
    echo "Install failed, uninstalling old version and retrying..."
    adb -s "$DEVICE" uninstall "$PKG" 2>/dev/null || true
    adb -s "$DEVICE" install "$APK"
  fi
  echo "Launching app..."
  adb -s "$DEVICE" shell am start -n "$PKG/.MainActivity"
  echo "App deployed at $(date '+%H:%M:%S')"
}

# Initial build + install
build_and_install

# Watch for .dart file changes and rebuild
echo "Watching /app/lib for changes..."
HASH_FILE="/tmp/dart_hash"
get_hash() { find /app/lib -name '*.dart' -exec md5sum {} \; 2>/dev/null | sort | md5sum; }
get_hash > "$HASH_FILE"

while true; do
  sleep 2
  NEW_HASH=$(get_hash)
  OLD_HASH=$(cat "$HASH_FILE")
  if [ "$NEW_HASH" != "$OLD_HASH" ]; then
    echo "$NEW_HASH" > "$HASH_FILE"
    echo "[watch] Dart file change detected, rebuilding..."
    build_and_install || echo "[watch] Build failed, waiting for next change..."
  fi
done
