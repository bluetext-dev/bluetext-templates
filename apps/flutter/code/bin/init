#!/bin/sh
set -e

echo "Initializing Flutter app..."

# On ARM64, install x86 multiarch libraries so OrbStack/Rosetta can run
# Android SDK's x86 tools (adb, aapt2, d8, etc.) transparently.
if [ "$(uname -m)" = "aarch64" ] && [ ! -f /usr/lib/x86_64-linux-gnu/ld-linux-x86-64.so.2 ]; then
  echo "Installing x86 multiarch libraries for Android SDK tools..."
  dpkg --add-architecture amd64

  # Pin existing sources to arm64 only
  sed -i '/^Architectures:/d; /^Types:/a Architectures: arm64' /etc/apt/sources.list.d/ubuntu.sources 2>/dev/null || true

  # Add amd64 sources from archive.ubuntu.com
  cat > /etc/apt/sources.list.d/amd64.list << 'SOURCES'
deb [arch=amd64] http://archive.ubuntu.com/ubuntu/ noble main restricted universe multiverse
deb [arch=amd64] http://archive.ubuntu.com/ubuntu/ noble-updates main restricted universe multiverse
deb [arch=amd64] http://archive.ubuntu.com/ubuntu/ noble-security main restricted universe multiverse
SOURCES

  apt-get update -qq
  apt-get install -y -qq libc6:amd64 libstdc++6:amd64 zlib1g:amd64 >/dev/null 2>&1

  # Ensure the x86-64 dynamic linker is reachable
  mkdir -p /usr/lib64
  ln -sf /usr/lib/x86_64-linux-gnu/ld-linux-x86-64.so.2 /usr/lib64/ld-linux-x86-64.so.2
fi

# Accept Android licenses
yes | flutter doctor --android-licenses 2>/dev/null || true

# Get dependencies
flutter pub get

echo "Initialization complete."
