<config xmlns="http://tail-f.com/ns/config/1.0">
  <environments xmlns="https://curity.se/ns/conf/base">
    <environment>
      <services>
        <service-role>
          <id>default</id>
          <endpoints>um-api-ep</endpoints>
        </service-role>
      </services>
    </environment>
  </environments>

  <profiles xmlns="https://curity.se/ns/conf/base">
    <profile>
      <id>token-service</id>
      <type xmlns:as="https://curity.se/ns/conf/profile/oauth">as:oauth-service</type>
      <settings>
        <authorization-server xmlns="https://curity.se/ns/conf/profile/oauth">
          <client-capabilities>
            <client-credentials/>
          </client-capabilities>
          <client-store>
            <config-backed>
              <client>
                <id>um-admin-client</id>
                <client-name>User Management Admin</client-name>
                <secret>um-admin-secret</secret>
                <capabilities>
                  <client-credentials/>
                </capabilities>
              </client>
            </config-backed>
          </client-store>
        </authorization-server>
      </settings>
    </profile>

    <profile>
      <id>user-mgmt</id>
      <type xmlns:um="https://curity.se/ns/conf/profile/user-management">um:user-management-service</type>
      <endpoints>
        <endpoint>
          <id>um-api-ep</id>
          <uri>/um</uri>
          <endpoint-kind>um-api</endpoint-kind>
        </endpoint>
      </endpoints>
      <settings>
        <user-management-service xmlns="https://curity.se/ns/conf/profile/user-management">
          <account-manager>default-account-manager</account-manager>
          <api-authentication>
            <oauth-service>token-service</oauth-service>
          </api-authentication>
        </user-management-service>
      </settings>
    </profile>
  </profiles>
</config>
