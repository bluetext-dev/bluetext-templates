<config xmlns="http://tail-f.com/ns/config/1.0">
  <environments xmlns="https://curity.se/ns/conf/base">
    <environment>
      <base-url>http://curity.{{namespace}}.bluetext.lvh.me:8888</base-url>
      <services>
        <service-role>
          <id>default</id>
          <protocol>http</protocol>
          <endpoints>auth-service-authentication</endpoints>
          <endpoints>auth-service-registration</endpoints>
          <endpoints>token-service-anonymous</endpoints>
          <endpoints>token-service-authorize</endpoints>
          <endpoints>token-service-token</endpoints>
          <endpoints>token-service-introspect</endpoints>
          <endpoints>token-service-userinfo</endpoints>
        </service-role>
      </services>
    </environment>
  </environments>

  <facilities xmlns="https://curity.se/ns/conf/base">
    <data-sources>
      <data-source>
        <id>default-datasource</id>
        <jdbc xmlns="https://curity.se/ns/ext-conf/jdbc">
          <connection-string>jdbc:hsqldb:file:/opt/idsvr/var/hsqldb/curity</connection-string>
          <driver>org.hsqldb.jdbc.JDBCDriver</driver>
          <standard-credentials-mode/>
          <attribute-query>SELECT "attributes" as account_data FROM "accounts" WHERE "username" = :subject</attribute-query>
        </jdbc>
      </data-source>
    </data-sources>
    <caching-services>
      <default-caching-service>
        <data-source>default-datasource</data-source>
      </default-caching-service>
    </caching-services>
  </facilities>

  <processing xmlns="https://curity.se/ns/conf/base">
    <account-managers>
      <account-manager>
        <id>default-account-manager</id>
        <account-data-source>default-datasource</account-data-source>
        <enable-registration>
          <account-verification-method>no-verification</account-verification-method>
        </enable-registration>
      </account-manager>
    </account-managers>
    <credential-managers>
      <credential-manager>
        <id>default-credential-manager</id>
        <data-source-backed>
          <data-source-id>default-datasource</data-source-id>
        </data-source-backed>
      </credential-manager>
    </credential-managers>
  </processing>

  <profiles xmlns="https://curity.se/ns/conf/base">
    <profile>
      <id>auth-service</id>
      <type xmlns:auth="https://curity.se/ns/conf/profile/authentication">auth:authentication-service</type>
      <endpoints>
        <endpoint>
          <id>auth-service-authentication</id>
          <uri>/authn</uri>
          <endpoint-kind>auth-authentication</endpoint-kind>
        </endpoint>
        <endpoint>
          <id>auth-service-registration</id>
          <uri>/authn/registration</uri>
          <endpoint-kind>auth-registration</endpoint-kind>
        </endpoint>
      </endpoints>
      <settings>
        <authentication-service xmlns="https://curity.se/ns/conf/profile/authentication">
          <authenticators>
            <authenticator>
              <id>html-form</id>
              <html-form xmlns="https://curity.se/ns/conf/authenticators/html-form">
                <account-manager>default-account-manager</account-manager>
                <credential-manager>default-credential-manager</credential-manager>
              </html-form>
            </authenticator>
          </authenticators>
          <protocols>
            <protocol>
              <id>simple-api-protocol</id>
              <simple-api/>
            </protocol>
          </protocols>
        </authentication-service>
      </settings>
    </profile>

    <profile>
      <id>token-service</id>
      <type xmlns:as="https://curity.se/ns/conf/profile/oauth">as:oauth-service</type>
      <token-issuers>
        <default-token-issuer>
          <default-data-source>default-datasource</default-data-source>
          <jwt-issuer-settings>
            <signing-key-id>default-signing-key</signing-key-id>
          </jwt-issuer-settings>
        </default-token-issuer>
      </token-issuers>
      <endpoints>
        <endpoint>
          <id>token-service-anonymous</id>
          <uri>/oauth/v2/oauth-anonymous</uri>
          <endpoint-kind>oauth-anonymous</endpoint-kind>
        </endpoint>
        <endpoint>
          <id>token-service-authorize</id>
          <uri>/oauth/v2/oauth-authorize</uri>
          <endpoint-kind>oauth-authorize</endpoint-kind>
        </endpoint>
        <endpoint>
          <id>token-service-token</id>
          <uri>/oauth/v2/oauth-token</uri>
          <endpoint-kind>oauth-token</endpoint-kind>
        </endpoint>
        <endpoint>
          <id>token-service-introspect</id>
          <uri>/oauth/v2/oauth-introspect</uri>
          <endpoint-kind>oauth-introspect</endpoint-kind>
        </endpoint>
        <endpoint>
          <id>token-service-userinfo</id>
          <uri>/oauth/v2/oauth-userinfo</uri>
          <endpoint-kind>oauth-userinfo</endpoint-kind>
        </endpoint>
      </endpoints>
      <settings>
        <authorization-server xmlns="https://curity.se/ns/conf/profile/oauth">
          <account-manager>default-account-manager</account-manager>
          <authentication-service>
            <authentication-profile>auth-service</authentication-profile>
          </authentication-service>
          <client-capabilities>
            <code/>
            <introspection/>
          </client-capabilities>
          <client-store>
            <config-backed>
              <client>
                <id>flutter-app</id>
                <client-name>Flutter App</client-name>
                <no-authentication>true</no-authentication>
                <redirect-uris>com.bluetext.app://callback</redirect-uris>
                <redirect-uris>http://localhost:3000/callback</redirect-uris>
                <scope>openid</scope>
                <scope>profile</scope>
                <scope>email</scope>
                <scope>roles</scope>
                <capabilities>
                  <code/>
                </capabilities>
                <proof-key>
                  <require-proof-key>true</require-proof-key>
                </proof-key>
                <use-pairwise-subject-identifiers>
                  <sector-identifier>bluetext-flutter</sector-identifier>
                </use-pairwise-subject-identifiers>
              </client>
              <client>
                <id>phantom-token-client</id>
                <client-name>Kong Phantom Token Introspection</client-name>
                <secret>phantom-token-secret</secret>
                <capabilities>
                  <introspection/>
                </capabilities>
              </client>
            </config-backed>
          </client-store>
          <scopes>
            <scope>
              <id>openid</id>
            </scope>
            <scope>
              <id>profile</id>
              <claims>name</claims>
              <claims>given_name</claims>
              <claims>family_name</claims>
            </scope>
            <scope>
              <id>email</id>
              <claims>email</claims>
            </scope>
            <scope>
              <id>roles</id>
              <claims>roles</claims>
            </scope>
          </scopes>
          <claims>
            <claim>
              <name>email</name>
              <value-provided-by>account-claims</value-provided-by>
            </claim>
            <claim>
              <name>name</name>
              <value-provided-by>account-claims</value-provided-by>
              <transformation>
                <input-attribute-names>given_name</input-attribute-names>
                <input-attribute-names>family_name</input-attribute-names>
                <value-transformation-procedure></value-transformation-procedure>
              </transformation>
            </claim>
            <claim>
              <name>given_name</name>
              <value-provided-by>account-claims</value-provided-by>
            </claim>
            <claim>
              <name>family_name</name>
              <value-provided-by>account-claims</value-provided-by>
            </claim>
            <claim>
              <name>roles</name>
              <value-provided-by>roles</value-provided-by>
              <transformation>
                <input-attribute-names>account_data</input-attribute-names>
                <value-transformation-procedure></value-transformation-procedure>
              </transformation>
            </claim>
            <claims-value-provider>
              <id>account-claims</id>
              <account-manager-claims-provider xmlns="https://curity.se/ns/ext-conf/account-manager-claims-provider">
                <account-manager>
                  <id>default-account-manager</id>
                </account-manager>
              </account-manager-claims-provider>
            </claims-value-provider>
            <claims-value-provider>
              <id>roles</id>
              <data-source-claims-provider xmlns="https://curity.se/ns/ext-conf/data-source-claims-provider">
                <data-source>
                  <data-source>default-datasource</data-source>
                </data-source>
              </data-source-claims-provider>
            </claims-value-provider>
            <claims-mappers>
              <claims-mapper>
                <id>default</id>
                <access_token>
                  <claim>email</claim>
                  <claim>name</claim>
                  <claim>given_name</claim>
                  <claim>family_name</claim>
                  <claim>roles</claim>
                </access_token>
                <id_token>
                  <claim>email</claim>
                  <claim>name</claim>
                  <claim>given_name</claim>
                  <claim>family_name</claim>
                  <claim>roles</claim>
                </id_token>
                <userinfo>
                  <claim>email</claim>
                  <claim>name</claim>
                  <claim>given_name</claim>
                  <claim>family_name</claim>
                  <claim>roles</claim>
                </userinfo>
              </claims-mapper>
              <default-claims-mapper>default</default-claims-mapper>
            </claims-mappers>
          </claims>
          <openid-connect>
            <expose-metadata/>
          </openid-connect>
        </authorization-server>
      </settings>
    </profile>
  </profiles>
</config>
