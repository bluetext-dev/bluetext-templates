{
  "bootstrap": {
    "server": "couchbase://couchbase.dev.svc.cluster.local",
    "username": "sync_gateway",
    "password": "password",
    "use_tls_server": false,
    "server_tls_skip_verify": true
  },
  "api": {
    "public_interface": ":4984",
    "admin_interface": ":4985",
    "admin_interface_authentication": false
  },
  "logging": {
    "console": {
      "enabled": true,
      "log_level": "info",
      "log_keys": ["*"]
    }
  },
  "databases": {
    "main": {
      "bucket": "main",
      "num_index_replicas": 0,
      "guest": {
        "disabled": false,
        "admin_channels": ["*"]
      }
    }
  }
}
