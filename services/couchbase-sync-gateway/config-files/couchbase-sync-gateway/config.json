{
  "bootstrap": {
    "server": "couchbase://couchbase.couchbase-headless.__NAMESPACE__.svc.cluster.local",
    "username": "Administrator",
    "password": "password",
    "server_tls_skip_verify": true,
    "use_tls_server": false
  },
  "api": {
    "public_interface": ":4984",
    "admin_interface": ":4985",
    "admin_interface_authentication": false
  },
  "logging": {
    "console": {
      "enabled": true,
      "log_level": "info",
      "log_keys": ["*"]
    }
  }
}
