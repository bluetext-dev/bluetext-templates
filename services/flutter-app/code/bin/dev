#!/bin/sh
set -e

if [ -z "$BLUETEXT_NAMESPACE" ]; then
  echo "Error: BLUETEXT_NAMESPACE is not set" >&2
  exit 1
fi

FLUTTER_FIFO="/tmp/flutter_stdin"
rm -f "$FLUTTER_FIFO"
mkfifo "$FLUTTER_FIFO"

echo "Flutter dev server starting (namespace: $BLUETEXT_NAMESPACE)"
echo "Send 'r' to $FLUTTER_FIFO for hot reload, 'R' for hot restart"
exec tail -f "$FLUTTER_FIFO" | flutter run -d emulator-5554 --dart-define=NAMESPACE="$BLUETEXT_NAMESPACE"
