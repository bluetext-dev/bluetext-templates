#!/bin/sh
set -e

echo "Initializing Flutter app..."

SDK="/opt/android-sdk-linux"
CACHE="/sdk-cache"

# On ARM64, install x86 multiarch libraries so OrbStack/Rosetta can run
# Android SDK's x86 tools (adb, aapt2, d8, etc.) transparently.
if [ "$(uname -m)" = "aarch64" ] && [ ! -f /usr/lib/x86_64-linux-gnu/ld-linux-x86-64.so.2 ]; then
  echo "Installing x86 multiarch libraries for Android SDK tools..."
  dpkg --add-architecture amd64

  # Pin existing sources to arm64 only
  sed -i '/^Architectures:/d; /^Types:/a Architectures: arm64' /etc/apt/sources.list.d/ubuntu.sources 2>/dev/null || true

  # Add amd64 sources from archive.ubuntu.com
  cat > /etc/apt/sources.list.d/amd64.list << 'SOURCES'
deb [arch=amd64] http://archive.ubuntu.com/ubuntu/ noble main restricted universe multiverse
deb [arch=amd64] http://archive.ubuntu.com/ubuntu/ noble-updates main restricted universe multiverse
deb [arch=amd64] http://archive.ubuntu.com/ubuntu/ noble-security main restricted universe multiverse
SOURCES

  apt-get update -qq
  apt-get install -y -qq libc6:amd64 libstdc++6:amd64 zlib1g:amd64 >/dev/null 2>&1

  # Ensure the x86-64 dynamic linker is reachable
  mkdir -p /usr/lib64
  ln -sf /usr/lib/x86_64-linux-gnu/ld-linux-x86-64.so.2 /usr/lib64/ld-linux-x86-64.so.2
fi

# Persist Android SDK downloads across pod restarts.
# Copy base image SDK content to cache on first run, then symlink so all
# future downloads (NDK, platforms, CMake, build-tools) land in the cache.
for dir in ndk cmake platforms build-tools; do
  if [ ! -d "$CACHE/$dir" ]; then
    mkdir -p "$CACHE/$dir"
    # Copy any pre-existing content from the base image
    cp -a "$SDK/$dir/"* "$CACHE/$dir/" 2>/dev/null || true
  fi

  # Validate cached NDK versions have source.properties (corrupted downloads lack it)
  if [ "$dir" = "ndk" ]; then
    for ndk_ver in "$CACHE/ndk/"*/; do
      [ -d "$ndk_ver" ] || continue
      if [ ! -f "$ndk_ver/source.properties" ]; then
        echo "Removing corrupted NDK cache: $ndk_ver"
        rm -rf "$ndk_ver"
      fi
    done
  fi

  # Replace with symlink to cache
  if [ ! -L "$SDK/$dir" ]; then
    rm -rf "$SDK/$dir"
    ln -sf "$CACHE/$dir" "$SDK/$dir"
  fi
done

# Accept Android licenses
yes | flutter doctor --android-licenses 2>/dev/null || true

# Get dependencies — skip when `pubspec.lock` hasn't changed since the last
# successful resolve. The marker file lives in the persistent pub-cache mount
# so it survives pod restarts the same way the package archives do. Falls
# through to a real `flutter pub get` whenever the marker, the lock, or the
# resolved package_config.json look out of sync — recovers cleanly from any
# weird state on its own.
PUB_LOCK_HASH=$(md5sum /app/pubspec.lock 2>/dev/null | awk '{print $1}')
PUB_LOCK_MARKER=/root/.pub-cache/.bluetext-resolved-lock-hash

if [ -n "$PUB_LOCK_HASH" ] \
   && [ -f "$PUB_LOCK_MARKER" ] \
   && [ "$(cat "$PUB_LOCK_MARKER" 2>/dev/null)" = "$PUB_LOCK_HASH" ] \
   && [ -f /app/.dart_tool/package_config.json ]; then
  echo "pub get: cache-hit (pubspec.lock unchanged) — skipping"
else
  echo "pub get: cache-miss — resolving dependencies"
  flutter pub get
  if [ -n "$PUB_LOCK_HASH" ]; then
    mkdir -p "$(dirname "$PUB_LOCK_MARKER")"
    echo "$PUB_LOCK_HASH" > "$PUB_LOCK_MARKER"
  fi
fi

echo "Initialization complete."
